# ============================================
# Nextcloud Self-Hosted Deployment — Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to the repository.
# ============================================

# ============================================
# Core Nextcloud
# ============================================
NEXTCLOUD_URL=https://cloud.example.com
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASS=change-me
NEXTCLOUD_VERSION=30.0.2
NEXTCLOUD_DOMAIN=cloud.example.com
NEXTCLOUD_DATA_DIR=/data/nextcloud

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRESQL_VERSION=16
POSTGRESQL_DB=nextcloud
POSTGRESQL_USER=nextcloud
POSTGRESQL_PASSWORD=change-me

# ============================================
# Redis
# ============================================
REDIS_SOCKET=/var/run/redis/redis-server.sock
REDIS_MAXMEMORY=512mb

# ============================================
# PHP-FPM
# ============================================
PHP_VERSION=8.2
PHP_MEMORY_LIMIT=512M
PHP_OPCACHE_MEMORY=256M

# ============================================
# TLS / Let's Encrypt
# ============================================
TLS_EMAIL=admin@example.com
TLS_STAGING=false

# ============================================
# Keycloak SSO
# ============================================
KEYCLOAK_ENABLED=true
KEYCLOAK_URL=https://auth.example.com
KEYCLOAK_DOMAIN=auth.example.com
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASS=change-me
KEYCLOAK_REALM=nextcloud
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASS=change-me
KEYCLOAK_SAML_CLIENT_ID=nextcloud-saml
KEYCLOAK_OIDC_CLIENT_ID=nextcloud-oidc

# Nextcloud SAML/SSO app configuration:
NEXTCLOUD_SAML_ENABLED=true
NEXTCLOUD_SAML_IDP_ENTITY_ID=https://auth.example.com/realms/nextcloud
NEXTCLOUD_SAML_IDP_SSO_URL=https://auth.example.com/realms/nextcloud/protocol/saml
NEXTCLOUD_SAML_IDP_SLO_URL=https://auth.example.com/realms/nextcloud/protocol/saml
NEXTCLOUD_SAML_IDP_CERT=change-me
NEXTCLOUD_SAML_ATTR_MAPPING_UID=uid
NEXTCLOUD_SAML_ATTR_MAPPING_EMAIL=email
NEXTCLOUD_SAML_ATTR_MAPPING_DISPLAYNAME=cn
NEXTCLOUD_SAML_ALLOW_MULTIPLE_BACKENDS=true
NEXTCLOUD_SAML_AUTO_PROVISION=true

# ============================================
# Billing Stack
# ============================================
BILLING_ENABLED=true
BILLING_DOMAIN=billing.example.com

# Lago
LAGO_API_URL=https://billing.example.com/api
LAGO_API_KEY=change-me

# BTCPay Server
BTCPAY_ENABLED=true
BTCPAY_DOMAIN=pay.example.com
BTCPAY_STORE_ID=change-me
BTCPAY_API_KEY=change-me

# InvoicePlane
INVOICEPLANE_ENABLED=true
INVOICEPLANE_DOMAIN=invoice.example.com
INVOICEPLANE_DB_NAME=invoiceplane
INVOICEPLANE_DB_USER=invoiceplane
INVOICEPLANE_DB_PASS=change-me

# ============================================
# Collabora Online
# ============================================
COLLABORA_DOMAIN=office.example.com
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASS=change-me

# ============================================
# Talk / TURN
# ============================================
TURN_SERVER=turn.example.com
TURN_SECRET=change-me

# ============================================
# External Storage (S3/MinIO)
# ============================================
S3_BUCKET=nextcloud-data
S3_HOSTNAME=minio.internal:9000
S3_USE_SSL=true
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me

# ============================================
# LDAP (optional, Enterprise tier)
# ============================================
LDAP_ENABLED=false
LDAP_HOST=ldap.example.com
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=change-me

# ============================================
# Backup
# ============================================
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=6
BACKUP_RETENTION_YEARLY=2
BACKUP_TARGET=/backup/nextcloud
BACKUP_OFFSITE=s3://offsite-backup-bucket/nextcloud
BACKUP_KEYCLOAK_REALM=true

# ============================================
# Monitoring
# ============================================
GRAFANA_ADMIN_PASS=change-me
PROMETHEUS_RETENTION=30d

# ============================================
# Test Configuration
# ============================================
NEXTCLOUD_TEST_USER_PREFIX=testuser
NEXTCLOUD_TEST_BASIC_USER=testbasic
NEXTCLOUD_TEST_PRO_USER=testpro
NEXTCLOUD_TEST_ENTERPRISE_USER=testent

# Optional: for tests requiring external services
NEXTCLOUD_LDAP_HOST=
NEXTCLOUD_SAML_IDP_URL=
NEXTCLOUD_S3_BUCKET=
NEXTCLOUD_COLLABORA_URL=
NEXTCLOUD_TALK_TURN_URL=
NEXTCLOUD_KEYCLOAK_URL=
NEXTCLOUD_KEYCLOAK_REALM=nextcloud
NEXTCLOUD_KEYCLOAK_ADMIN_USER=admin
NEXTCLOUD_KEYCLOAK_ADMIN_PASS=change-me
NEXTCLOUD_KEYCLOAK_SAML_CLIENT_ID=nextcloud-saml
NEXTCLOUD_KEYCLOAK_OIDC_CLIENT_ID=nextcloud-oidc
NEXTCLOUD_LAGO_API_URL=
NEXTCLOUD_LAGO_API_KEY=change-me

# ============================================
# Ansible Vault
# ============================================
ANSIBLE_VAULT_PASSWORD=change-me

# ============================================
# GitHub Actions Secrets (set in repo settings, NOT here)
# ============================================
# ANSIBLE_VAULT_PASSWORD
# NEXTCLOUD_ADMIN_PASS
# KEYCLOAK_ADMIN_PASS
# LAGO_API_KEY
# BTCPAY_API_KEY
# GRAFANA_ADMIN_PASS
# All vault_* variables
