# {{ ansible_managed | default('Managed by Ansible — PostgreSQL role') }}
# PostgreSQL 16 configuration — tuned for Nextcloud with ~50 users
# Based on official PostgreSQL 16 default config with Nextcloud-optimized overrides

# -----------------------------------------------------------------------------
# CONNECTIONS AND AUTHENTICATION
# -----------------------------------------------------------------------------

listen_addresses = '{{ postgresql_listen_addresses }}'
port = 5432
max_connections = {{ postgresql_max_connections }}

# Reserved connections for superuser (maintenance during peak load)
superuser_reserved_connections = 3

# Authentication timeout
authentication_timeout = 1min

# SSL — disabled since Nextcloud connects locally
ssl = off

# -----------------------------------------------------------------------------
# RESOURCE USAGE (MEMORY)
# -----------------------------------------------------------------------------

# Shared buffers — 25% of system RAM for dedicated DB server
shared_buffers = {{ postgresql_shared_buffers }}

# Huge pages — try to use if available (reduces TLB pressure)
huge_pages = try

# Effective cache size — estimate of OS page cache + shared_buffers (~75% RAM)
effective_cache_size = {{ postgresql_effective_cache_size }}

# Work memory per sort/hash operation per connection
work_mem = {{ postgresql_work_mem }}

# Maintenance work memory (VACUUM, CREATE INDEX, etc.)
maintenance_work_mem = {{ postgresql_maintenance_work_mem }}

# Shared memory for parallel queries
min_dynamic_shared_memory = 0MB

# -----------------------------------------------------------------------------
# WAL (Write-Ahead Log)
# -----------------------------------------------------------------------------

wal_level = {{ postgresql_wal_level }}
fsync = on
synchronous_commit = on
wal_sync_method = fdatasync

# WAL buffers — 16MB is good for most workloads
wal_buffers = 16MB

# WAL writer flush interval
wal_writer_delay = 200ms
wal_writer_flush_after = 1MB

# Checkpoint tuning — reduce checkpoint I/O spikes
checkpoint_timeout = 15min
checkpoint_completion_target = 0.9
max_wal_size = 4GB
min_wal_size = 1GB

# WAL archiving for point-in-time recovery
archive_mode = {{ 'on' if postgresql_archive_mode | default(false) | bool else 'off' }}
archive_command = '{{ postgresql_archive_command | default('') }}'
archive_timeout = 0

# -----------------------------------------------------------------------------
# PLANNER / OPTIMIZER
# -----------------------------------------------------------------------------

# Random page cost — 1.1 for SSD, 4.0 for spinning disk
random_page_cost = {{ postgresql_random_page_cost }}

# Effective I/O concurrency — 200 for SSD
effective_io_concurrency = 200

# Planner statistics
default_statistics_target = 100

# Constraint exclusion — partition pruning
constraint_exclusion = partition

# -----------------------------------------------------------------------------
# QUERY TUNING
# -----------------------------------------------------------------------------

# Parallel query workers
max_worker_processes = 8
max_parallel_workers_per_gather = 2
max_parallel_workers = 8
max_parallel_maintenance_workers = 2
parallel_leader_participation = on

# JIT compilation — enable for analytical queries
jit = on

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

log_destination = 'stderr'
logging_collector = on
log_directory = 'log'
log_filename = 'postgresql-%Y-%m-%d_%H%M%S.log'
log_file_mode = 0600
log_rotation_age = 1d
log_rotation_size = 10MB
log_truncate_on_rotation = on

# What to log — capture slow queries and errors
log_min_duration_statement = 1000  # log queries taking >1s
log_checkpoints = on
log_connections = on
log_disconnections = on
log_lock_waits = on
log_temp_files = 0  # log all temp file usage
log_autovacuum_min_duration = 0  # log all autovacuum activity
log_error_verbosity = default
log_line_prefix = '%m [%p] %q%u@%d '

# -----------------------------------------------------------------------------
# AUTOVACUUM
# -----------------------------------------------------------------------------

autovacuum = on
autovacuum_max_workers = 3
autovacuum_naptime = 1min
autovacuum_vacuum_threshold = 50
autovacuum_vacuum_scale_factor = 0.05
autovacuum_vacuum_insert_threshold = 1000
autovacuum_vacuum_insert_scale_factor = 0.05
autovacuum_analyze_threshold = 50
autovacuum_analyze_scale_factor = 0.05
autovacuum_vacuum_cost_delay = 2ms
autovacuum_vacuum_cost_limit = 200

# -----------------------------------------------------------------------------
# CLIENT CONNECTION DEFAULTS
# -----------------------------------------------------------------------------

datestyle = 'iso, mdy'
timezone = 'UTC'
lc_messages = 'en_US.UTF-8'
lc_monetary = 'en_US.UTF-8'
lc_numeric = 'en_US.UTF-8'
lc_time = 'en_US.UTF-8'
default_text_search_config = 'pg_catalog.english'

# -----------------------------------------------------------------------------
# SHARED PRELOAD LIBRARIES
# -----------------------------------------------------------------------------

shared_preload_libraries = '{{ postgresql_shared_preload_libraries }}'

# pg_stat_statements settings
pg_stat_statements.track = {{ postgresql_pg_stat_statements_track | default('all') }}
pg_stat_statements.max = 5000

# -----------------------------------------------------------------------------
# LOCK MANAGEMENT
# -----------------------------------------------------------------------------

deadlock_timeout = 1s
max_locks_per_transaction = 64
max_pred_locks_per_transaction = 64

# -----------------------------------------------------------------------------
# VERSION / PLATFORM COMPATIBILITY
# -----------------------------------------------------------------------------

# These are PostgreSQL 16 defaults — kept for reference
# (uncomment to override if needed)
# array_nulls = on
# backslash_quote = safe_encoding
# escape_string_warning = on
# standard_conforming_strings = on
# synchronize_seqscans = on
