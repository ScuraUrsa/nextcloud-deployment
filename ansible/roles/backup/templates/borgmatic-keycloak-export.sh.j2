#!/bin/bash
# {{ ansible_managed | default('Managed by Ansible — backup role') }}
# Keycloak realm export script for borgmatic pre-backup hook
# Exports the Nextcloud realm configuration as JSON for backup

set -euo pipefail

KC_URL="https://localhost:{{ backup_keycloak_port }}"
REALM="{{ backup_keycloak_realm_name }}"
EXPORT_DIR="{{ backup_keycloak_export_dir }}"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
OUTPUT_FILE="${EXPORT_DIR}/${REALM}-realm-${TIMESTAMP}.json"

# Obtain admin access token
TOKEN=$(curl -s -k -X POST "${KC_URL}/realms/master/protocol/openid-connect/token"   -d "client_id=admin-cli"   -d "username={{ backup_keycloak_admin_user }}"   -d "password={{ backup_keycloak_admin_pass }}"   -d "grant_type=password" | jq -r '.access_token')

if [ -z "$TOKEN" ] || [ "$TOKEN" = "null" ]; then
  echo "ERROR: Failed to obtain Keycloak admin token" >&2
  exit 1
fi

# Export realm
HTTP_CODE=$(curl -s -k -w "%{http_code}" -X POST "${KC_URL}/admin/realms/${REALM}/export"   -H "Authorization: Bearer $TOKEN"   -H "Content-Type: application/json"   -d '{"exportClients":true,"exportGroupsAndRoles":true}'   -o "${OUTPUT_FILE}")

if [ "$HTTP_CODE" != "200" ]; then
  echo "ERROR: Keycloak realm export failed with HTTP ${HTTP_CODE}" >&2
  rm -f "${OUTPUT_FILE}"
  exit 1
fi

echo "Keycloak realm '${REALM}' exported to ${OUTPUT_FILE}"
