# auditd rules for Nextcloud deployment security monitoring
# Generated by Ansible hardening role

# Remove any existing rules to avoid duplicates
-D

# Increase audit backlog limit
-b 8192

# Fail silently if auditd is not running (for idempotent re-runs)
-f 1

## Nextcloud core files
-w {{ nextcloud_webroot }}/config/config.php -p wa -k nextcloud_config
-w {{ nextcloud_data_dir }} -p wa -k nextcloud_data

## occ execution monitoring
-a always,exit -F path={{ nextcloud_webroot }}/occ -F perm=x -F auid>=1000 -F auid!=unset -k nextcloud_occ

## Nginx configuration
-w /etc/nginx/nginx.conf -p wa -k nginx_config
-w /etc/nginx/sites-available/ -p wa -k nginx_config
-w /etc/nginx/sites-enabled/ -p wa -k nginx_config

## PHP configuration
-w /etc/php/ -p wa -k php_config

## SSL/TLS certificates
-w /etc/ssl/ -p wa -k ssl_certs
-w /etc/letsencrypt/ -p wa -k ssl_certs

## System authentication files
-w /etc/passwd -p wa -k system_auth
-w /etc/shadow -p wa -k system_auth
-w /etc/group -p wa -k system_auth
-w /etc/gshadow -p wa -k system_auth
-w /etc/sudoers -p wa -k system_auth
-w /etc/sudoers.d/ -p wa -k system_auth

## SSH configuration
-w /etc/ssh/sshd_config -p wa -k ssh_config
-w /etc/ssh/ -p wa -k ssh_config

## Cron and scheduled tasks
-w /etc/crontab -p wa -k cron_config
-w /etc/cron.d/ -p wa -k cron_config
-w /etc/cron.daily/ -p wa -k cron_config
-w /etc/cron.hourly/ -p wa -k cron_config
-w /etc/cron.weekly/ -p wa -k cron_config
-w /etc/cron.monthly/ -p wa -k cron_config
-w /var/spool/cron/crontabs/ -p wa -k cron_config

## fail2ban configuration
-w /etc/fail2ban/ -p wa -k fail2ban_config

## PostgreSQL data directory
-w /var/lib/postgresql/ -p wa -k postgresql_data
-w /etc/postgresql/ -p wa -k postgresql_config
