# AIDE (Advanced Intrusion Detection Environment) configuration
# Generated by Ansible hardening role for Nextcloud deployment
# Database location
database=file:/var/lib/aide/aide.db
database_out=file:/var/lib/aide/aide.db.new

# Report level (verbose)
report_url=file:/var/log/aide/aide.log
report_url=stdout

# Rule definitions
# p: permissions, i: inode, n: number of links, u: user, g: group
# s: size, b: block count, m: mtime, a: atime, c: ctime
# S: check for growing size, md5: md5 checksum, sha256: sha256 checksum
# RMD160: rmd160 checksum, TIGER: tiger checksum

# Full integrity check (everything except growing logs)
FULL = p+i+n+u+g+s+b+m+c+acl+selinux+xattrs+md5+sha256

# Log files (growing, so skip size checks)
LOG = p+i+n+u+g+acl+selinux+xattrs+md5+sha256

# Nextcloud webroot - full integrity
{{ nextcloud_webroot }} FULL

# Nextcloud data directory - permissions and ownership only (data changes constantly)
{{ nextcloud_data_dir }} p+i+n+u+g+acl+selinux+xattrs

# Nginx configuration
/etc/nginx FULL

# PHP configuration
/etc/php FULL

# SSL certificates
/etc/ssl FULL
/etc/letsencrypt FULL

# System authentication
/etc/passwd FULL
/etc/shadow FULL
/etc/group FULL
/etc/gshadow FULL
/etc/sudoers FULL
/etc/sudoers.d FULL

# SSH configuration
/etc/ssh FULL

# Cron configuration
/etc/crontab FULL
/etc/cron.d FULL
/etc/cron.daily FULL
/etc/cron.hourly FULL
/etc/cron.weekly FULL
/etc/cron.monthly FULL
/var/spool/cron/crontabs FULL

# fail2ban configuration
/etc/fail2ban FULL

# PostgreSQL
/etc/postgresql FULL
/var/lib/postgresql FULL

# System binaries (critical)
/bin FULL
/sbin FULL
/usr/bin FULL
/usr/sbin FULL

# Libraries
/lib FULL
/lib64 FULL
/usr/lib FULL
/usr/lib64 FULL

# Boot files
/boot FULL

# Logs (growing files)
/var/log LOG
