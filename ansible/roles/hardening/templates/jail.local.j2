# {{ ansible_managed }}
# fail2ban jail.local — generated by Ansible hardening role
# Enables jails for: Nextcloud, Nginx, SSH, Keycloak

[DEFAULT]
bantime = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
maxretry = {{ fail2ban_maxretry }}
ignoreip = 127.0.0.1/8 ::1
backend = auto
banaction = iptables-multiport
banaction_allports = iptables-allports

# ============================================================
# Nextcloud jail — parses JSON log for failed logins
# ============================================================
[nextcloud]
enabled = true
port = http,https
filter = nextcloud
logpath = {{ nextcloud_data_dir }}/nextcloud.log
maxretry = {{ fail2ban_maxretry }}

# ============================================================
# Nginx HTTP authentication failures (401/403)
# ============================================================
[nginx-auth]
enabled = true
port = http,https
filter = nginx-auth
logpath = /var/log/nginx/access.log
maxretry = {{ fail2ban_maxretry }}

# ============================================================
# Nginx bot search (scanners, crawlers hitting 404s)
# ============================================================
[nginx-botsearch]
enabled = true
port = http,https
filter = nginx-botsearch
logpath = /var/log/nginx/access.log
maxretry = {{ fail2ban_maxretry }}

# ============================================================
# SSH brute-force protection
# ============================================================
[sshd]
enabled = true
port = ssh
filter = sshd
logpath = /var/log/auth.log
maxretry = {{ fail2ban_maxretry }}

# ============================================================
# Keycloak authentication failures
# ============================================================
[keycloak]
enabled = true
port = http,https
filter = keycloak
logpath = /var/log/keycloak/*.log
maxretry = {{ fail2ban_maxretry }}
